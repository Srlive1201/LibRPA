<regressionsuite>

  <group name="RPA correlation energy">
    <testcase name="RPA, water molecules in box (aims input)" directory="rpa_aims_mole_H2O_libri">
      <build require_libri="true"
      />
      <run ntasks_disable="none"
           nthreads_disable="none"
           ntasks_enable="none"
           nthreads_enable="none"
      />
      <validate name="Correlation energy"
                regex="Total EcRPA: \s+([-+]?\d*\.\d+)"
                comparison="cmp_float.abs_diff(1e-4)"
      />
    </testcase>
  </group>

  <group name="Exact-exchange (EXX) potentials">
    <testcase name="BCC He, with eigenvector parllelized over k (aims input)" directory="exx_aims_bccHe_k_parallel_libri">
      <build require_libri="true"
      />
      <validate name="EXX potential on k-grid"
                regex="Band\s+e_exx.*e_exx"
                headers="1"
                rows="8"
                comparison="cmp_table.abs_diff(1e-4)"
      />
    </testcase>
  </group>

  <group name="One-shot GW quasi-particle energies (QPE)">
    <testcase name="Bulk silicon (aims input)" directory="g0w0_aims_Si_libri">
      <build require_libri="true"
      />
      <run ntasks_disable="none"
           nthreads_disable="none"
           ntasks_enable="none"
           nthreads_enable="none"
      />
      <validate name="Quasi-particle energies on k-grid"
                regex="State\s+occ\s+e_mf\s+v_xc\s+v_exx\s+ReSigc\s+ImSigc\s+e_qp"
                headers="2"
                rows="18"
                comparison="cmp_table.abs_diff(1e-4)"
      />
    </testcase>

    <testcase name="Lithium atom, spin-polarized (aims input)" directory="g0w0_aims_Li_atom_libri">
      <validate name="Quasi-particle energies on k-grid"
                regex="State\s+occ\s+e_mf\s+v_xc\s+v_exx\s+ReSigc\s+ImSigc\s+e_qp"
                headers="2"
                rows="5"
                comparison="cmp_table.abs_diff(1e-4)"
      />
    </testcase>

  </group>

</regressionsuite>
